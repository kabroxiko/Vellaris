{
  "name": "vellaris-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run make-favicon && vite",
    "build": "npm run make-favicon && vite build",
    "preview": "vite preview",
    "make-favicon": "sh scripts/make-favicon.sh",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,md,json}\""
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "prop-types": "^15.8.1",
    "vite": "^5.0.0"
  }
}
