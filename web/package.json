{
  "name": "vellaris-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run copy-assets && npm run make-favicon && vite",
    "build": "npm run copy-assets && npm run make-favicon && vite build",
    "copy-assets": "sh scripts/copy-assets.sh",
    "preview": "vite preview",
    "make-favicon": "sh scripts/make-favicon.sh",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,md,json}\"",
    "test": "vitest"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-color": "^2.19.3",
    "react-colorful": "^5.7.0",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prop-types": "^15.8.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
